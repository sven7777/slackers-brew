# SPA fallback for brew.slackersbrewing.com (static Vite build on DreamHost).
# Serve real files/dirs as-is; route everything else to index.html so client-side
# refreshes and the OAuth redirect (/?code=…) resolve instead of 404ing.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule . /index.html [L]
</IfModule>

# Long-cache the fingerprinted assets; never cache the HTML shell.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|woff2?|png|jpg|jpeg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
